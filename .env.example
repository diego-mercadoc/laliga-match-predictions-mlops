# API Configuration
API_KEY=your-api-key-here

# MLflow Configuration
MLFLOW_TRACKING_URI=http://mlflow:5000
DAGSHUB_USERNAME=your-username
DAGSHUB_TOKEN=your-token

# MinIO Configuration
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key

# Grafana Configuration
GRAFANA_ADMIN_PASSWORD=your-grafana-password

# Service Ports
BACKEND_PORT=8000
FRONTEND_PORT=8501
MLFLOW_PORT=5000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
PREFECT_PORT=4200

# Model Configuration
MODEL_REGISTRY_NAME=LaLigaPredictionsModel
MODEL_VERSION=champion

# Monitoring Configuration
PROMETHEUS_RETENTION_DAYS=15
GRAFANA_PROVISIONING_PATH=/etc/grafana/provisioning

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Security
CORS_ORIGINS=*
TRUSTED_HOSTS=*

# Retraining Configuration
RETRAINING_SCHEDULE_DAYS=7
MIN_SAMPLES_REQUIRED=1000
EVALUATION_PERIOD_DAYS=7

# A/B Testing
CHAMPION_TRAFFIC_FRACTION=0.8
CHALLENGER_TRAFFIC_FRACTION=0.2

# Data Pipeline
DATA_FETCH_RETRIES=3
DATA_FETCH_TIMEOUT=30

# Performance Thresholds
MIN_PREDICTION_ACCURACY=0.7
MAX_PREDICTION_LATENCY=0.5
MAX_ERROR_RATE=0.05

# Monitoring Intervals
DRIFT_CHECK_INTERVAL_HOURS=1
PERFORMANCE_REPORT_INTERVAL_DAYS=1

# Backup Configuration
BACKUP_S3_BUCKET=laliga-predictions-backups
BACKUP_FREQUENCY_HOURS=24
BACKUP_RETENTION_DAYS=90
BACKUP_COMPRESSION_LEVEL=6
BACKUP_MAX_LOCAL_SIZE_GB=10
BACKUP_PARALLEL_UPLOADS=3
BACKUP_ERROR_RETRY_COUNT=3
BACKUP_ERROR_RETRY_DELAY=300 